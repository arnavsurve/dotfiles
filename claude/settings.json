{
  "includeCoAuthoredBy": false,
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/asurve/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "lapdog@lapdog": true,
    "linear-cli@linear-cli": true,
    "paper-desktop@paper": true
  },
  "extraKnownMarketplaces": {
    "lapdog": {
      "source": {
        "source": "github",
        "repo": "DataDog/dd-apm-test-agent"
      }
    },
    "paper": {
      "source": {
        "source": "github",
        "repo": "paper-design/agent-plugins"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto"
}
