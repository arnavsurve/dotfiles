{
  "name": "pi-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/main.ts\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/dist/main.js",
    "build:server": "tsx server/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src server",
    "lint:fix": "oxlint --fix src server",
    "format": "oxfmt src server",
    "format:check": "oxfmt --check src server"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@octokit/rest": "^22.0.0",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.7.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
